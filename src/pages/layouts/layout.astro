---
const { title } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | STEMoon</title>
	</head>
  <body>
    <img src="/moon.webp" alt="background image" class="bgmoon" width="1500px" />
    <slot />
    <footer>
        <p class="p7">Made by a student, for students. <br /> <span class="smalltext">Copyright © 2026 STEMoon. All rights reserved.</span></p>
    </footer>
  </body>
</html>

<style>
	
	@font-face {
		font-family: 'Planet Kosmos';
		src: url('/fonts/PLANK___.woff2') format('woff2');
	}
	main {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 880px;
		margin: 0 auto;

	}
	body {
		display: flex;
		flex-direction: column;
		font-family: 'Planet Kosmos';
		margin: 2;
		font-size: 1.4em;
		padding: 20px;
		background-color: #000000;
		color: #bebebe;
		letter-spacing: 0.2em;
	}
	.hero {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 100vh;
		@media (max-width: 960px) {
			flex-direction: column;
			text-align: center;
			margin: 0 auto;
		}
	}
	h1 {
		color: #e1e5e8;
	}

	.h1small {
		color: #e1e5e8;
		font-size: 0.8em;
	}

	p {
		color: #e1e5e8;
		font-size: 1em;
		letter-spacing: 0.1em;
	}
	.p2 {
		position: fixed;
		bottom: 10px;
		left: 50%;
		transform: translateX(-50%);
		font-family: Georgia;
		color: #d2f1ff;
		font-size: 0.8em;
		font-style: italic;
		letter-spacing: -0.01em;
		text-align: center;
	}
	.p3 {
		margin-top: 150px;
		font-family: Georgia;
		color: #596ee8;
		font-size: 2em;
		font-style: italic;
		letter-spacing: -0.01em;
		text-align: left;
	}
	.p4 {
		margin-top: 200px;
		font-family: Georgia;
		color: #bfc7f1;
		font-size: 1.2em;
		font-style: italic;
		letter-spacing: -0.01em;
		text-align: left;
	}
	.p5 {
		margin-top: 20px;
		font-family: Georgia;
		color: #a0c8f0;
		font-size: 1.2em;
		font-style: italic;
		letter-spacing: -0.01em;
		text-align: left;
	}
	.p6 {
		margin-top: 35px;
		font-family: Georgia;
		color: #8480f2;
		font-size: 1.4em;
		font-style: italic;
		letter-spacing: -0.01em;
		text-align: center;
	}
	.p7 {

		font-family: Georgia;
		color: #ffffff;
		font-size: 0.7em;
		font-style: italic;
		letter-spacing: -0.01em;
		text-align: center;
	}
	.p5nsp {
		margin-top: 0px;
		font-family: Georgia;
		color: #9ec7f0;
		font-size: 1.2em;
		font-style: italic;
		letter-spacing: -0.01em;
		text-align: left;
	}
	.highlight {
		color: #675fff;
	}
	.highlight2 {
		color: #ffea9f;
	}
	.smalltext {
		color: #9ec7f0;
		display: block;
		font-size: 0.7em;
		margin-top: 5px;
		line-height: 1em;
	}
	hr {
		width: 100%;
	}
	.bgmoon {
		position: fixed;
		left: -300px;
		top: 50%;
		min-width: 760px;
		transform: translateY(-50%);
		opacity: 0.2;
		width: 100%;
		height: 100%;
		object-fit: cover;
		z-index: -1;
	}
	.buttons {
		display: flex;
		gap: 20px;
		margin-top: 30px;
		justify-content: center;
	}
	.btn {
		color: #f1f1f1;
		text-align: center;
		padding: 10px 20px;
		border-radius: 3px;
		text-decoration: none;
		transition: background-color 0.3s, color 0.3s;
	}
	.btn:hover {
		background-color: #675fff;
		transition: transform 0.3s;
		transform: scale(.95);
	}
	.btn2 {
		color: #f1f1f1;
		font-size: 1.6em;
		text-align: center;
		padding: 10px 20px;
		border-radius: 3px;
		text-decoration: none;
		transition: background-color 0.3s, color 0.3s;
	}
	.btn2:hover {
		background-color: #a47c2c;
		transition: transform 0.3s;
		transform: scale(.95);
	}
	.previouslyblackbglmao {
		width: 100%;
		margin-left: -30px;
		padding-left: 30px;
		padding-right: 30px;
		min-height: 30vh;
	}
</style>
<style is:global>
    @media (max-width: 1500px) {
        html {
            font-size: 20%;
        }
    }
</style>
