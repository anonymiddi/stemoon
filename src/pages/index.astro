---
import { Image } from 'astro:assets';

---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>STEMoon</title>
	</head>
	<body>
		<img src="/moon.webp" alt="background image" class="bgmoon" width="1500px" />
		<main>
			<section class="hero">
				<Image src="/stemoonlogo_white.webp" alt="STEMoon Logo" width={300} height={300} />
				<div class="text-content">
					<h1>STEM<span class="h1small">oon</span></h1>
					<p>shoot for the <span class="highlight">moon</span>; land among the <span class="highlight2">stars</span></p>
				</div>
			</section>
		</main>
		<p class="p2">scroll down...</p>
		<hr />
		<p class="p3">Ever complained about the lack of unified study sources? <br /> Yeah, me too.
		</p>
		<p class="p4">A student had to endure the distracted research for study resources online for two years straight so you don't have to. (Or, at least; so the process is easier for ya)
		</p>
		<p class="p5">A student's study materials, dedicated for other students students; something I have ensured to be:
			<ul class="p5nsp">
				<li>restructured for intuitive study</li>
				<li>organized for active recall</li>
				<li>minimally designed</li>
				<li><strong>teacher-reviewed</strong></li>
				<li><strong>distraction-free (p.s no ads :D )</strong></li>
				<li>free; with absolutely <span class="highlight2">no strings attached</span><span class="smalltext"> <br />(donations are available JUST to keep the site up; as of May 2026, it has been 100% self-financed.) </span> </li>
			</ul> 
			<hr />
		</p>
		<div class="previouslyblackbglmao">
			<p class="p6">A <strong>stellar</strong> future is awaiting. Act upon that.</p>
			<div class="buttons">
				<a href="/start" class="btn2">Start</a>
				<a href="/about" class="btn">About this project</a>
				<a href="/purpose" class="btn">Purpose</a>
			</div>
		</div>
		<hr />
		<footer>
			<p class="p7">Made by a student, for students. <br /> <span class="smalltext">Copyright © 2026 STEMoon. All rights reserved.</span></p>
	</body>
</html>

<style>
	
	@font-face {
		font-family: 'Planet Kosmos';
		src: url('/fonts/PLANK___.woff2') format('woff2');
	}
	main {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 880px;
		margin: 0 auto;

	}
	body {
		display: flex;
		flex-direction: column;
		font-family: 'Planet Kosmos';
		margin: 2;
		font-size: 1.4em;
		padding: 20px;
		background-color: #000000;
		color: #bebebe;
		letter-spacing: 0.2em;
	}
	.hero {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 100vh;
		@media (max-width: 960px) {
			flex-direction: column;
			text-align: center;
			margin: 0 auto;
		}
	}
	h1 {
		color: #e1e5e8;
	}

	.h1small {
		color: #e1e5e8;
		font-size: 0.8em;
	}

	p {
		color: #e1e5e8;
		font-size: 1em;
		letter-spacing: 0.1em;
	}
	.p2 {
		position: fixed;
		bottom: 10px;
		left: 50%;
		transform: translateX(-50%);
		font-family: Georgia;
		color: #d2f1ff;
		font-size: 0.8em;
		font-style: italic;
		letter-spacing: -0.01em;
		text-align: center;
	}
	.p3 {
		margin-top: 150px;
		font-family: Georgia;
		color: #596ee8;
		font-size: 2em;
		font-style: italic;
		letter-spacing: -0.01em;
		text-align: left;
	}
	.p4 {
		padding-inline-start: 1%;
		padding-inline-end: 1%;
		margin-top: 200px;
		font-family: Georgia;
		color: #bfc7f1;
		font-size: 1.2em;
		font-style: italic;
		letter-spacing: -0.01em;
		text-align: left;
	}
	.p5 {
		padding-inline-start: 3%;
		padding-inline-end: 3%;
		margin-top: 20px;
		font-family: Georgia;
		color: #a0c8f0;
		font-size: 1.2em;
		font-style: italic;
		letter-spacing: -0.01em;
		text-align: left;
	}
	.p6 {
		margin-top: 35px;
		font-family: Georgia;
		color: #9693df;
		font-size: 1.4em;
		font-style: italic;
		letter-spacing: -0.01em;
		text-align: center;
	}
	.p7 {

		font-family: Georgia;
		color: #ffffff;
		font-size: 0.7em;
		font-style: italic;
		letter-spacing: -0.01em;
		text-align: center;
	}
	.p5nsp {
		padding-inline-start: 150px;
		padding-inline-end: 70px;
		margin-top: 0px;
		font-family: Georgia;
		color: #9ec7f0;
		font-size: 1.2em;
		font-style: italic;
		letter-spacing: -0.01em;
		text-align: left;
	}
	.highlight {
		color: #675fff;
	}
	.highlight2 {
		color: #ffea9f;
	}
	.smalltext {
		color: #9ec7f0;
		display: block;
		font-size: 0.7em;
		margin-top: 5px;
		line-height: 1em;
	}
	hr {
		width: 100%;
	}
	.bgmoon {
		position: fixed;
		left: -300px;
		top: 50%;
		min-width: 760px;
		transform: translateY(-50%);
		opacity: 0.2;
		width: 100%;
		height: 100%;
		object-fit: cover;
		z-index: -1;
	}
	.buttons {
		display: flex;
		gap: 20px;
		margin-top: 30px;
		justify-content: center;
		@media (max-width: 950px) {
		flex-direction: column;
		margin-left: 0;
		margin-top: 20px;
	}
	}
	.btn {
		color: #f1f1f1;
		text-align: center;
		padding: 10px 20px;
		font-size: 1.6em;
		border-radius: 3px;
		text-decoration: none;
		transition: background-color 0.3s, color 0.3s;
	}
	.btn:hover {
		background-color: #675fff;
		transition: transform 0.3s;
		transform: scale(.95);
	}
	.btn2 {
		color: #f1f1f1;
		font-size: 1.6em;
		text-align: center;
		padding: 10px 20px;
		border-radius: 3px;
		text-decoration: none;
		transition: background-color 0.3s, color 0.3s;
	}
	.btn2:hover {
		background-color: #a47c2c;
		transition: transform 0.3s;
		transform: scale(.95);
	}
	.previouslyblackbglmao {
		width: 100%;
		margin-left: -30px;
		padding-left: 30px;
		padding-right: 30px;
		min-height: 30vh;
	}
</style>


<script>
	const scrollHint2 = document.querySelector<HTMLElement>('.p2');
	window.addEventListener('scroll', () => {
		const opacity = 1 - (window.scrollY / 150);
		if (scrollHint2) {
			scrollHint2.style.opacity = `${opacity}`;
		}
	});
</script>
